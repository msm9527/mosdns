<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>mosdns E2E Report</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f5f7fb;
      --card: #ffffff;
      --line: #d9e0ea;
      --text: #16202a;
      --muted: #5d6b7a;
      --pass: #107a3f;
      --pass-bg: #e9f8ef;
      --fail: #b42318;
      --fail-bg: #fff0ee;
    }
    body {
      margin: 0;
      padding: 32px;
      background: linear-gradient(180deg, #f7f8fc 0%, #eef3f8 100%);
      color: var(--text);
      font: 14px/1.6 "SFMono-Regular", "Menlo", "Monaco", monospace;
    }
    .wrap {
      max-width: 1080px;
      margin: 0 auto;
    }
    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(16, 24, 40, 0.06);
      padding: 24px;
      margin-bottom: 20px;
    }
    h1, h2 {
      margin: 0 0 12px;
      font-weight: 700;
    }
    .meta {
      color: var(--muted);
    }
    .summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin-top: 16px;
    }
    .pill {
      border-radius: 12px;
      padding: 14px 16px;
      border: 1px solid var(--line);
    }
    .status-passed {
      color: var(--pass);
      background: var(--pass-bg);
    }
    .status-failed {
      color: var(--fail);
      background: var(--fail-bg);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
    }
    th, td {
      padding: 12px 10px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
    }
    th {
      color: var(--muted);
      font-weight: 600;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .badge {
      display: inline-block;
      border-radius: 999px;
      padding: 2px 10px;
      font-size: 12px;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card">
      <h1>mosdns E2E Report</h1>
      <div class="meta">生成时间: {{ .GeneratedAt }} | 总耗时: {{ .Duration }}</div>
      <div class="summary">
        <div class="pill {{ if eq .Status "passed" }}status-passed{{ else }}status-failed{{ end }}">
          <div>Suite</div>
          <strong>{{ .Status }}</strong>
        </div>
        <div class="pill">
          <div>Total Cases</div>
          <strong>{{ .Total }}</strong>
        </div>
        <div class="pill status-passed">
          <div>Passed</div>
          <strong>{{ .Passed }}</strong>
        </div>
        <div class="pill status-failed">
          <div>Failed</div>
          <strong>{{ .Failed }}</strong>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Cases</h2>
      <table>
        <thead>
          <tr>
            <th>Case</th>
            <th>Status</th>
            <th>Duration</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          {{ range .Cases }}
          <tr>
            <td>{{ .Name }}</td>
            <td>
              <span class="badge {{ if eq .Status "passed" }}status-passed{{ else }}status-failed{{ end }}">
                {{ .Status }}
              </span>
            </td>
            <td>{{ .Duration }}</td>
            <td>{{ .Detail }}</td>
          </tr>
          {{ end }}
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
